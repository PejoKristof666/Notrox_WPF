<Window x:Class="Notrox.View.EditAddressesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Notrox.View"
        mc:Ignorable="d"
        Title="EditAddressesWindow" 
        Height="440"
        Width="400"
        Background="#081225"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <StackPanel Margin="20" Background="#1E293B">

        <TextBlock Text="Szállítási cím" FontWeight="Bold" Foreground="White"/>

        <TextBlock Text="Város" Margin="5 5 5 -5" Foreground="White"></TextBlock>
        <TextBox Text="{Binding ShippingCity}" IsReadOnly="True" Margin="5"/>
        <TextBlock Text="Irányítószám" Margin="5 5 5 -5" Foreground="White"></TextBlock>
        <TextBox Text="{Binding ShippingZip}" IsReadOnly="True" Margin="5"/>
        <TextBlock Text="Cím" Margin="5 5 5 -5" Foreground="White"></TextBlock>
        <TextBox Text="{Binding ShippingAddress}" IsReadOnly="True" Margin="5"/>

        <Separator Margin="0,10"/>

        <TextBlock Text="Számlázási cím" FontWeight="Bold" Foreground="White"/>

        <TextBlock Text="Város" Margin="5 5 5 -5" Foreground="White"></TextBlock>
        <TextBox Text="{Binding BillingCity}" IsReadOnly="True" Margin="5"/>
        <TextBlock Text="Irányítószám" Margin="5 5 5 -5" Foreground="White"></TextBlock>
        <TextBox Text="{Binding BillingZip}" IsReadOnly="True" Margin="5"/>
        <TextBlock Text="Számlázási cím" Margin="5 5 5 -5" Foreground="White"></TextBlock>
        <TextBox Text="{Binding BillingAddress}" IsReadOnly="True" Margin="5"/>

    </StackPanel>
</Window>
