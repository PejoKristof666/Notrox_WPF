<Application x:Class="Notrox.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Notrox"
             xmlns:vm="clr-namespace:Notrox.ViewModel"
             xmlns:view="clr-namespace:Notrox.View"
             StartupUri="/View/MainWindow.xaml">
    <Application.Resources>
        <DataTemplate DataType="{x:Type vm:UsersViewModel}">
            <view:Users/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:OrdersViewModel}">
            <view:Orders/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ProductsViewModel}">
            <view:Products/>
        </DataTemplate>
    </Application.Resources>
</Application>
