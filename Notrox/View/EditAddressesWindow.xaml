<Window x:Class="Notrox.View.EditAddressesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Notrox.View"
        mc:Ignorable="d"
        Title="EditAddressesWindow" 
        Height="440"
        Width="400"
        Background="#081225"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <StackPanel Margin="20" Background="#1E293B">

        <TextBlock Text="Shipping Address" FontWeight="Bold" Foreground="White"/>

        <TextBlock Text="City" Margin="5 5 5 -5" Foreground="White"></TextBlock>
        <TextBox Text="{Binding ShippingCity, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
        <TextBlock Text="ZipCode" Margin="5 5 5 -5" Foreground="White"></TextBlock>
        <TextBox Text="{Binding ShippingZip, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
        <TextBlock Text="Address" Margin="5 5 5 -5" Foreground="White"></TextBlock>
        <TextBox Text="{Binding ShippingAddress, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>

        <Separator Margin="0,10"/>

        <TextBlock Text="Billing Address" FontWeight="Bold" Foreground="White"/>

        <TextBlock Text="City" Margin="5 5 5 -5" Foreground="White"></TextBlock>
        <TextBox Text="{Binding BillingCity, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
        <TextBlock Text="ZpiCode" Margin="5 5 5 -5" Foreground="White"></TextBlock>
        <TextBox Text="{Binding BillingZip, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
        <TextBlock Text="BillingAddress" Margin="5 5 5 -5" Foreground="White"></TextBlock>
        <TextBox Text="{Binding BillingAddress, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
    
        <Button Content="Save" Margin="0,15,0,0" Width="100" Command="{Binding SaveCommand}"/>
    </StackPanel>
</Window>
