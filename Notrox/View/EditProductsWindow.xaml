<Window x:Class="Notrox.View.EditProductsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Notrox.View"
        mc:Ignorable="d"
        Title="Edit Product" 
        Height="550" 
        Width="420"
        Background="#081225"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid>

        <Border Background="#1E293B"
                CornerRadius="10"
                Padding="25"
                Width="320"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel>

                <TextBlock Text="Edit Product"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,20"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Product Name"
                           Foreground="White"
                           FontWeight="SemiBold"/>
                <TextBox Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,5,0,15"
                         Height="30"/>

                <TextBlock Text="Description"
                           Foreground="White"
                           FontWeight="SemiBold"/>
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,5,0,15"
                         Height="30"/>

                <TextBlock Text="Price"
                           Foreground="White"
                           FontWeight="SemiBold"/>
                <TextBox Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,5,0,15"
                         Height="30"/>

                <TextBlock Text="Stock Amount"
                           Foreground="White"
                           FontWeight="SemiBold"/>
                <TextBox Text="{Binding Ammount, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,5,0,15"
                         Height="30"/>

                <TextBlock Text="Image URL"
                           Foreground="White"
                           FontWeight="SemiBold"/>
                <TextBox Text="{Binding IMGURL, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,5,0,20"
                         Height="30"/>

                <Button Content="Save Changes"
                        Command="{Binding SaveCommand}"
                        Height="35"
                        FontWeight="SemiBold"
                        Background="#2E86DE"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>
