<Window x:Class="Notrox.View.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Notrox.View"
        mc:Ignorable="d"
        Title="AdminWindow" WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        Background="#0F172A"
        Icon="../Resources/Notrox.ico">
    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <Border Grid.RowSpan="2"
            Background="#081225"
            Padding="20"
            BorderBrush="White"
            BorderThickness="0,0,0.5,0">
    
            <StackPanel>

                <TextBlock Text="NOTROX"
                    Foreground="White"
                    FontSize="22"
                    FontWeight="Bold"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0 0 0 0"/>
                
                <Image Source="../Resources/Notrox.png" Height="auto" Width="auto" HorizontalAlignment="Center" Margin="0 -25 0 -30"></Image>
                

                <Button Content="Felhasználók"
                        Height="40"
                        Margin="0,6"
                        Background="#1E293B"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding ShowUsers}"/>

                <Button Content="Rendelések"
                        Height="40"
                        Margin="0,6"
                        Background="#1E293B"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding ShowOrders}"/>

                <Button Content="Termékek"
                        Height="40"
                        Margin="0,6"
                        Background="#1E293B"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding ShowProducts}"/>
                
                <Button Content="Termék hozzáadása"
                        Height="40"
                        Margin="0,6"
                        Background="#1E293B"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding AddProduct}"/>

                <Button Content="Felhasználók mentése (CSV)"
                        Height="40"
                        Margin="0,6"
                        Background="#1E293B"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding SaveToCSV}"/>
            </StackPanel>

        </Border>


        <Border Grid.Column="1"
            Background="#081225"
            Padding="20">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Keresés:"
                    
                    Foreground="#94A3B8"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center"
                    Margin="550,0,10,0"/>

                <TextBox Width="280"
                     Height="35"
                     Background="#1E293B"
                     Foreground="White"
                     BorderThickness="0"
                     Padding="10"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     VerticalAlignment="Center"/>

                <Button Content="Kijelentkezés"
                    Grid.Column="2"
                    Height="35"
                    Width="80"
                    Margin="10,0,0,0"
                    Background="#1E293B"
                    Foreground="Red"
                    BorderThickness="0"
                    Cursor="Hand"
                    VerticalAlignment="Center"
                    Click="Logout"/>

                <TextBlock Grid.Column="1"
                    Text="{Binding AdminName, StringFormat=Admin: {0}}"
                    Foreground="Cyan"
                    VerticalAlignment="Center"
                    FontWeight="Bold"
                    Margin="20,0,0,0"/>
                
            </Grid>

        </Border>

        <Border Grid.Row="1" Grid.Column="1" Padding="35">

            <ContentControl Content="{Binding CurrentView}"/>

        </Border>
        
    </Grid>
</Window>
