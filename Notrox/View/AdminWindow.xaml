<Window x:Class="Notrox.View.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Notrox.View"
        mc:Ignorable="d"
        Title="AdminWindow" WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        Background="#0F172A"
        Icon="../Resources/Notrox.ico">
    <Grid>

        <!-- Layout -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <!-- SIDEBAR -->
        <Border Grid.RowSpan="2"
            Background="#081225"
            Padding="20"
            BorderBrush="White"
            BorderThickness="0,0,0.5,0">
    
            <StackPanel>

                <!-- Logo -->
                <TextBlock Text="NOTROX"
                    Foreground="White"
                    FontSize="22"
                    FontWeight="Bold"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0 0 0 0"/>
                <Image Source="../Resources/Notrox.png" Height="auto" Width="auto" HorizontalAlignment="Center" Margin="0 -25 0 -30"></Image>
                
                <!-- Menu Buttons -->

                <Button Content="Users"
                        Height="40"
                        Margin="0,6"
                        Background="#1E293B"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding ShowUsers}"/>

                <Button Content="Orders"
                        Height="40"
                        Margin="0,6"
                        Background="#1E293B"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding ShowOrders}"/>

                <Button Content="Products"
                        Height="40"
                        Margin="0,6"
                        Background="#1E293B"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding ShowProducts}"/>
                
                <Button Content="Add Product"
                       Height="40"
                       Margin="0,6"
                       Background="#1E293B"
                       Foreground="White"
                       BorderThickness="0"
                       Cursor="Hand"
                       Command="{Binding AddProduct}"/>
            </StackPanel>

        </Border>


        <!-- TOP BAR -->
        <Border Grid.Column="1"
            Background="#081225"
            Padding="20">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <TextBox Width="280"
                     Height="35"
                     Background="#1E293B"
                     Foreground="White"
                     BorderThickness="0"
                     Padding="10"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     VerticalAlignment="Center"/>

                <!-- Admin text -->
                <Button Content="Logout"
                    Grid.Column="2"
                    Height="35"
                    Width="80"
                    Margin="10,0,0,0"
                    Background="#1E293B"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    VerticalAlignment="Center"
                    Click="Logout"/>
                
                <TextBlock Grid.Column="1"
                       Text="{Binding AdminName, StringFormat=Admin: {0}}"
                       Foreground="White"
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Margin="20,0,0,0"/>
                
            </Grid>

        </Border>


        <!-- MAIN CONTENT -->
        <Border Grid.Row="1"
                Grid.Column="1"
                Padding="35">

            <ContentControl Content="{Binding CurrentView}"/>

        </Border>
        
    </Grid>
</Window>
