<UserControl x:Class="Notrox.View.Orders"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Notrox.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <ItemsControl ItemsSource="{Binding OrdersView}" Margin="30">
            <ItemsControl.ItemTemplate>
                <DataTemplate>

                    <Border Background="Gray"
                            CornerRadius="12"
                            Padding="15"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0 5">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding Id, StringFormat='{}#{0}'}"
                                       Grid.Column="0"
                                       Foreground="Cyan"
                                       VerticalAlignment="Center"
                                       Padding="0 17 0 0"
                                       Width="100"
                                       Height="40"
                                       Margin="0 0 0 10"/>

                            <TextBlock Text="{Binding Date}"
                                       Grid.Column="1"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Padding="0 0 0 0"
                                       FontSize="15"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="{Binding TotalPrice, StringFormat='{}{0} Ft'}"
                                       Grid.Column="2"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Padding="0 0 0 0"
                                       FontSize="15"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"/>

                            <ComboBox ItemsSource="{Binding DataContext.Chooses, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      SelectedItem="{Binding SelectedPhase, Mode=TwoWay}"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Stretch"
                                      Grid.Column="3"
                                      Margin="0 0 0 0">
                            </ComboBox>

                            <Button Content="Save"
                                    FontSize="15"
                                    Grid.Column="4"
                                    Height="25"
                                    Width="40"
                                    Margin="5"
                                    Background="green"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Command="{Binding DataContext.EditOrder, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                        </Grid>
                    </Border>

                </DataTemplate>
            </ItemsControl.ItemTemplate>

        </ItemsControl>

    </ScrollViewer>
</UserControl>
